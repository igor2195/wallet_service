# PostgreSQL
POSTGRES_DB=wallet
POSTGRES_USER=myuser
POSTGRES_PASSWORD=secret
POSTGRES_PORT=5432

# App
APP_PORT=8080

# HikariCP
DB_POOL_MAX_SIZE=50
DB_POOL_MIN_IDLE=10
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000
DB_LEAK_DETECTION=60000

# Retry
WALLET_RETRY_MAX_ATTEMPTS=5
WALLET_RETRY_DELAY=100
WALLET_RETRY_MULTIPLIER=2
WALLET_RETRY_MAX_DELAY=5000

# Hibernate
HIBERNATE_BATCH_SIZE=20
HIBERNATE_FETCH_SIZE=50
HIBERNATE_SHOW_SQL=false
HIBERNATE_FORMAT_SQL=false

# Liquibase
LIQUIBASE_ENABLED=true
LIQUIBASE_CHANGE_LOG=classpath:db/liquibase/db.changelog-master.xml

# Security
JWT_SECRET=YXNkZmdoamtscXdlcnR5dWlvcGZmZ2hmamdsa2poZ2Zkc2FmZ2hmZ2prbGg
JWT_EXP=86400000